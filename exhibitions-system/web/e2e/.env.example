# انسخ هذا الملف إلى e2e/.env واملأ القيم، أو صدّرها كمتغيّرات بيئة قبل التشغيل.

# رابط الموقع (المباشر أو المحلي)
E2E_BASE_URL=https://www.sindbadsa.com

# بيانات مالك مطعم (إيميل + كلمة مرور المشترك) — ضع بيانات حسابك
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=

# بيانات موظف (نادل) — موجودة جاهزة لقهوة الساعة
E2E_EMP_PHONE=0999000001
E2E_EMP_CODE=472913

# معرّف المستأجر لرابط الطلب أونلاين /menu/:tenantId (قهوة الساعة)
E2E_TENANT_ID=9986cc69-51e3-4b7a-a671-76a87d9f8f2f

# اضبطها = 1 لتشغيل اختبارات تُنشئ بيانات فعلية (تفتح طاولة/طلب) — افتراضيًا متوقّفة
E2E_RUN_FLOWS=0
